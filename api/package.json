    "aws-sdk-client-mock-jest": "^4.1.0",
    "babel-jest": "^30.0.2",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "ts-jest": "^29.4.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.0",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1"
